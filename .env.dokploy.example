# Dokploy 环境变量模板
#
# 用途：
# 1. 可复制为本地 `.env` 后配合 `docker-compose.yml` 使用
# 2. 可将其中变量录入 Dokploy 的 Variables / Secrets
#
# 说明：
# - 当前默认值按“腾讯云测试环境 2 核 4G”准备
# - “正式机器 4 核 8G”建议值见文末注释块
# - 当前测试环境机器：腾讯云 `2 核 4G / 60GB SSD / 30Mbps`
# - 当前测试环境系统：`OpenCloudOS 9.4`
# - 当前测试环境面板：`http://43.156.68.154:3000`

############################
# 通用基础配置
############################

TZ=Asia/Shanghai

# 应用镜像
# 推荐改为你自己的 GHCR 镜像，例如：
# APP_IMAGE=ghcr.io/your-github-owner/new-api-private:test
APP_IMAGE=calciumion/new-api:latest

# PostgreSQL
POSTGRES_USER=root
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=new-api
POSTGRES_HOST=postgres

# Redis
REDIS_PASSWORD=change-me-redis-password
REDIS_HOST=redis

# 安全相关
# 可用 `openssl rand -hex 32` 生成
SESSION_SECRET=change-me-session-secret
CRYPTO_SECRET=change-me-crypto-secret
TRUSTED_REDIRECT_DOMAINS=idtoken.ai

############################
# 当前节点信息
############################

NODE_TYPE=master
NODE_NAME=new-api-test

############################
# 测试环境推荐值（2 核 4G）
############################

MEMORY_CACHE_ENABLED=true
BATCH_UPDATE_ENABLED=true
SYNC_FREQUENCY=60

SQL_MAX_OPEN_CONNS=20
SQL_MAX_IDLE_CONNS=8
SQL_MAX_LIFETIME=300

REDIS_POOL_SIZE=20

RELAY_MAX_IDLE_CONNS=100
RELAY_MAX_IDLE_CONNS_PER_HOST=50

STREAMING_TIMEOUT=180
MAX_REQUEST_BODY_MB=4
MAX_FILE_DOWNLOAD_MB=4

ERROR_LOG_ENABLED=false
UPDATE_TASK=false
CountToken=false

############################
# 正式机器参考值（4 核 8G）
############################

# 如切换到正式机器，可按需改成以下值：
#
# APP_IMAGE=ghcr.io/your-github-owner/new-api-private:v2026.04.23-1
# NODE_NAME=new-api-1
# SYNC_FREQUENCY=30
#
# SQL_MAX_OPEN_CONNS=60
# SQL_MAX_IDLE_CONNS=20
# SQL_MAX_LIFETIME=300
#
# REDIS_POOL_SIZE=50
#
# RELAY_MAX_IDLE_CONNS=500
# RELAY_MAX_IDLE_CONNS_PER_HOST=150
#
# STREAMING_TIMEOUT=180
# MAX_REQUEST_BODY_MB=8
# MAX_FILE_DOWNLOAD_MB=8
#
# ERROR_LOG_ENABLED=false
# UPDATE_TASK=false
# CountToken=false
